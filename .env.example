# ── OIDC / JWT verification ────────────────────────────────────────────────────
# Option A — HS256 with Supabase JWT secret (simpler, good for getting started)
#   Get this from: Supabase dashboard > Settings > API > JWT Settings > JWT Secret
OIDC_SECRET=your-supabase-jwt-secret

# Option B — RS256 with JWKS endpoint (more secure, provider-agnostic)
#   Leave OIDC_SECRET empty and set these instead:
# OIDC_JWKS_URI=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# OIDC_ISSUER=https://<project-ref>.supabase.co/auth/v1

# Supabase audience (default: "authenticated" — matches Supabase JWT aud claim)
OIDC_AUDIENCE=authenticated

# ── Supabase admin (Phase 2 – user profiles) ───────────────────────────────────
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
